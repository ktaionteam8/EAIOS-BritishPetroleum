# ─────────────────────────────────────────────────────────────────────────────
# EAIOS-BP Backend — Environment Variables
#
# Primary Hosting Strategy (cloud-only, no local DB required):
#   Frontend  → Vercel    https://vercel.com  — set REACT_APP_API_URL in project settings
#   Backend   → Render    https://render.com  — paste these vars into the Render dashboard
#   Database  → Supabase  https://supabase.com — PostgreSQL, no local DB needed
#   Cache     → Upstash   https://upstash.com — serverless Redis, TLS
#
# For local development:
#   cp .env.example .env  — fill in DATABASE_URL, SECRET_KEY, ANTHROPIC_API_KEY
#   NEVER commit .env to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Database — Supabase PostgreSQL (required) ─────────────────────────────────
# Supabase dashboard → Settings → Database → Connection string → URI
# Use the Transaction pooler (port 6543) for Render serverless:
#   postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or direct connection (port 5432) for persistent processes:
#   postgresql+asyncpg://postgres.[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Redis — Upstash (production) or local Docker (dev) ───────────────────────
# Production (Upstash): rediss://default:[PASSWORD]@[HOST].upstash.io:6380
# Local dev:            redis://localhost:6379
REDIS_URL=rediss://default:[YOUR-UPSTASH-PASSWORD]@[YOUR-UPSTASH-HOST].upstash.io:6380

# ── App ───────────────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# On Render, SECRET_KEY is auto-generated via render.yaml — no manual action needed.
SECRET_KEY=your-64-char-random-hex-here
ENVIRONMENT=production

# ── CORS — Vercel frontend URL ────────────────────────────────────────────────
# Set to your Vercel deployment URL. CORS allowed_origins inherits this value
# automatically. For multiple origins use ALLOWED_ORIGINS (comma-separated).
FRONTEND_URL=https://eaios-bp.vercel.app
# ALLOWED_ORIGINS=https://eaios-bp.vercel.app,https://preview-branch.vercel.app

# ── Auth Users — JWT login credentials ───────────────────────────────────────
# JSON mapping of username → bcrypt password hash.
# Generate a hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# Example (replace hashes with real ones):
#   AUTH_USERS='{"admin": "$2b$12$...", "trader": "$2b$12$..."}'
# On Render: set this as a secret environment variable in the dashboard.
AUTH_USERS={}

# ── Anthropic / Claude API ────────────────────────────────────────────────────
# Required for AI Advisor chat (POST /api/chat)
# Get your key from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
