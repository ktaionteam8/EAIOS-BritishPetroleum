# ─────────────────────────────────────────────────────────────
# EAIOS-BP Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Cloud PostgreSQL) ─────────────────────
# Get your password from: https://supabase.com/dashboard/project/hnmsgojeexhyhsrlhgcv/settings/database
DATABASE_URL=postgresql+asyncpg://postgres.[YOUR-PASSWORD]@db.hnmsgojeexhyhsrlhgcv.supabase.co:5432/postgres

# ── Redis (local) ────────────────────────────────────────────
# Run locally via Docker: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
