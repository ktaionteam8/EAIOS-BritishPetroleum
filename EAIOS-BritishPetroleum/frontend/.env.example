# ─────────────────────────────────────────────────────────────
# EAIOS-BP Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────
# URL of the running FastAPI backend
REACT_APP_API_URL=http://localhost:8000

# ── Supabase (optional — for direct frontend queries) ─────────
REACT_APP_SUPABASE_URL=https://hnmsgojeexhyhsrlhgcv.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-anon-key-here
